%% =========================
%% Core "Brain" + State Machine
%% =========================
class EnemyBrainBase {
  <<MonoBehaviour>>
  +bool IsDead
  +int CurrentHealth
  +Rigidbody2D RB
  +bool IsFacingRight
  +LayerMask SpottableMask
  +float CurrentPoise
  +float maxSpotRange
  +AttackSOBase attack
  +float maxPoise
  +List~ISpottable~ VisibleSpottables
  +Transform ClosestTarget
  +ISpottable AttackTarget
  +Vector3 InitialPosition
  +Vector3 LastKnownTargetPosition
  +bool HasLastKnownTarget
  +bool isSpottableDetected
  +bool isSpottableInAttackRange

  +void TakeDamage(DamageData)
  +void Die()
  +void MoveEnemy(Vector2,bool)
  +void MoveTo(Transform)
  +void MoveTo(GameObject)
  +void MoveTo(Vector2)
  +void CheckForLeftOrRightFacing(Vector2)
}

class EnemyFlyingBrainBase {
  <<MonoBehaviour>>
  %% overrides detection + movement to be "circle-based" + 2D flight movement
}

class EnemyStateMachine {
  +EnemyBaseState CurrentState
  +EnemyBaseState PreviousState
  +EnemyBaseState NextState
  +void InitializeDefaultState(EnemyBaseState)
  +void RequestStateChange(EnemyBaseState,string)
  +void ApplyQueuedStateChange()
}

class EnemyBaseState {
  <<ScriptableObject>>
  #EnemyBrainBase EnemyBrainBase
  #EnemyStateMachine StateMachine
  +void StateInit(EnemyBrainBase,EnemyStateMachine)
  +void StateEnter()
  +void StateExit()
  +void StateUpdate()
  +void StateFixedUpdate()
  +void TransitionChecks()
  +void DrawGizmosOnSelected(EnemyBrainBase)
}

EnemyBrainBase o-- EnemyStateMachine : owns
EnemyStateMachine --> EnemyBaseState : Current/Next/Prev
EnemyBrainBase "1" -- "3" EnemyBaseState : plug-in states\n(noSpot/detected/inRange)
EnemyBaseState ..> EnemyBrainBase : reads flags + commands movement

EnemyFlyingBrainBase --|> EnemyBrainBase : extends

